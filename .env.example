# ====== LLM Provider 配置 ======
# 不配置 OPENAI_API_KEY 时，自动使用内置 Mock 模型（离线可运行）

# OpenAI 兼容接口的 API Key（可选）
OPENAI_API_KEY=

# OpenAI 兼容接口的 Base URL（可选，默认官方地址）
# 例如使用第三方/自建兼容服务时填写
OPENAI_BASE_URL=

# 使用的模型名（默认 gpt-4o-mini）
MODEL=gpt-4o-mini

# ====== Agent 行为配置 ======
# 主代理最大推理步数
MAX_STEPS=40

# 累计 token 预算上限（粗略成本护栏，chars/4 估算口径）；0 表示不限制
MAX_TOKENS=0

# 子代理最大推理步数
SUBAGENT_MAX_STEPS=20

# 工具/构建/测试失败后的最大反思重试次数（代码任务建议 2-3，给修复留余地）
MAX_REFLECT_RETRIES=2

# 触发上下文裁剪的消息条数阈值
CONTEXT_LIMIT=24

# 命令执行工具的超时时间（毫秒）
COMMAND_TIMEOUT_MS=15000

# 默认运行模式：react | plan | auto
DEFAULT_MODE=auto

# 工作目录（默认为当前所在目录 cwd；指定后以该目录为沙箱根）
# WORKDIR=

# ====== 上下文压缩配置 ======
# 压缩策略：hybrid（LLM 摘要为主、本地为辅，默认）| llm | local
COMPRESS_MODE=hybrid

# 估算 token 阈值，超过即触发压缩（chars/4 估算口径）
# 默认按模型窗口推导：256K 窗口 - 摘要预留 20K - 压缩缓冲 16K ≈ 220K
COMPRESS_TOKEN_THRESHOLD=220000

# 压缩时保留最近 N 条原文消息
COMPRESS_KEEP_RECENT=16

# 摘要体积上限（字符），控制压缩比
COMPRESS_MAX_SUMMARY_CHARS=2400

